CREATE DATABASE SkyLodge;
USE SkyLodge;

CREATE TABLE Categoria_Quarto(
id_categoria INT AUTO_INCREMENT PRIMARY KEY,
nome_categoria VARCHAR(100),
descricao VARCHAR(150),
valor_diaria DECIMAL(10,2)
);

CREATE TABLE Quarto(
id_quarto INT AUTO_INCREMENT PRIMARY KEY,
numero INT,
andar VARCHAR(20),
status VARCHAR(30),
id_categoria INT,

FOREIGN KEY(id_categoria)
REFERENCES Categoria_Quarto(id_categoria)
);

CREATE TABLE Cliente(
id_cliente INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR(100),
cpf VARCHAR(14),
telefone VARCHAR(20),
email VARCHAR(100)
);

CREATE TABLE Reserva(
id_reserva INT AUTO_INCREMENT PRIMARY KEY,
data_reserva DATE,
data_entrada DATE,
data_saida DATE,
status VARCHAR(30),
id_cliente INT,
id_quarto INT,

FOREIGN KEY(id_cliente)
REFERENCES Cliente(id_cliente),

FOREIGN KEY(id_quarto)
REFERENCES Quarto(id_quarto)
);

CREATE TABLE Consumo(
id_consumo INT AUTO_INCREMENT PRIMARY KEY,
descricao VARCHAR(100),
valor DECIMAL(10,2),
data_consumo DATE,
id_reserva INT,

FOREIGN KEY(id_reserva)
REFERENCES Reserva(id_reserva)
);

CREATE TABLE Limpeza(
id_limpeza INT AUTO_INCREMENT PRIMARY KEY,
data_limpeza DATE,
funcionario VARCHAR(100),
observacoes TEXT,
id_quarto INT,

FOREIGN KEY(id_quarto)
REFERENCES Quarto(id_quarto)
);

CREATE TABLE Checkin_Checkout(
id_check INT AUTO_INCREMENT PRIMARY KEY,
checkin DATETIME,
checkout DATETIME,
status VARCHAR(30),
id_reserva INT UNIQUE,

FOREIGN KEY(id_reserva)
REFERENCES Reserva(id_reserva)
);

ALTER TABLE Categoria_Quarto
ADD status_ativo BOOLEAN DEFAULT TRUE;

ALTER TABLE Quarto
ADD data_cadastro DATE;

ALTER TABLE Cliente
ADD observacoes TEXT;

ALTER TABLE Reserva
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Consumo
ADD forma_pagamento VARCHAR(30);

ALTER TABLE Limpeza
ADD status_servico VARCHAR(30);

ALTER TABLE Checkin_Checkout
ADD observacoes TEXT;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarCategoria(
IN p_nome VARCHAR(100),
IN p_descricao VARCHAR(150),
IN p_valor DECIMAL(10,2)
)
BEGIN

IF p_valor > 0 THEN

INSERT INTO Categoria_Quarto
(nome_categoria, descricao, valor_diaria)
VALUES
(p_nome, p_descricao, p_valor);

ELSE

SELECT 'Valor da diária inválido.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarQuarto(
IN p_numero INT,
IN p_andar VARCHAR(20),
IN p_status VARCHAR(30),
IN p_categoria INT
)
BEGIN

DECLARE existe INT;

SELECT COUNT(*) INTO existe
FROM Categoria_Quarto
WHERE id_categoria = p_categoria;

IF existe > 0 THEN

INSERT INTO Quarto
(numero, andar, status, id_categoria)
VALUES
(p_numero, p_andar, p_status, p_categoria);

ELSE

SELECT 'Categoria não encontrada.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarCliente(
IN p_nome VARCHAR(100),
IN p_cpf VARCHAR(14),
IN p_telefone VARCHAR(20),
IN p_email VARCHAR(100)
)
BEGIN

IF EXISTS(
SELECT *
FROM Cliente
WHERE email = p_email)

THEN

SELECT 'Email já cadastrado.' AS Mensagem;

ELSE

INSERT INTO Cliente
(nome, cpf, telefone, email)
VALUES
(p_nome, p_cpf, p_telefone, p_email);

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarReserva(
IN p_data DATE,
IN p_entrada DATE,
IN p_saida DATE,
IN p_status VARCHAR(30),
IN p_cliente INT,
IN p_quarto INT
)
BEGIN

DECLARE situacao VARCHAR(30);

SELECT status
INTO situacao
FROM Quarto
WHERE id_quarto = p_quarto;

IF situacao = 'Disponivel' THEN

INSERT INTO Reserva
(data_reserva, data_entrada, data_saida, status, id_cliente, id_quarto)

VALUES
(p_data, p_entrada, p_saida, p_status, p_cliente, p_quarto);

UPDATE Quarto
SET status='Reservado'
WHERE id_quarto=p_quarto;

ELSE

SELECT 'Quarto indisponível.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_RegistrarConsumo(
IN p_descricao VARCHAR(100),
IN p_valor DECIMAL(10,2),
IN p_data DATE,
IN p_reserva INT
)
BEGIN

IF EXISTS(
SELECT *
FROM Reserva
WHERE id_reserva=p_reserva)

THEN

INSERT INTO Consumo
(descricao, valor, data_consumo, id_reserva)

VALUES
(p_descricao, p_valor, p_data, p_reserva);

ELSE

SELECT 'Reserva não encontrada.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_AgendarLimpeza(
IN p_data DATE,
IN p_funcionario VARCHAR(100),
IN p_obs TEXT,
IN p_quarto INT
)
BEGIN

IF EXISTS(
SELECT *
FROM Quarto
WHERE id_quarto=p_quarto)

THEN

INSERT INTO Limpeza
(data_limpeza, funcionario, observacoes, id_quarto)

VALUES
(p_data, p_funcionario, p_obs, p_quarto);

ELSE

SELECT 'Quarto inexistente.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_Checkin(
IN p_checkin DATETIME,
IN p_checkout DATETIME,
IN p_status VARCHAR(30),
IN p_reserva INT
)
BEGIN

IF EXISTS(
SELECT *
FROM Reserva
WHERE id_reserva=p_reserva)

THEN

INSERT INTO Checkin_Checkout
(checkin, checkout, status, id_reserva)

VALUES
(p_checkin, p_checkout, p_status, p_reserva);

UPDATE Reserva
SET status='Hospedado'
WHERE id_reserva=p_reserva;

ELSE

SELECT 'Reserva não encontrada.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_reservar_quarto
AFTER INSERT ON Reserva
FOR EACH ROW
BEGIN

UPDATE Quarto
SET status = 'Reservado'
WHERE id_quarto = NEW.id_quarto;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_criar_checkin
AFTER INSERT ON Reserva
FOR EACH ROW
BEGIN

INSERT INTO Checkin_Checkout
(checkin, checkout, status, id_reserva)

VALUES
(NULL, NULL, 'Pendente', NEW.id_reserva);

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_liberar_quarto
AFTER UPDATE ON Checkin_Checkout
FOR EACH ROW
BEGIN

IF NEW.checkout IS NOT NULL THEN

UPDATE Quarto q
JOIN Reserva r
ON q.id_quarto = r.id_quarto

SET q.status = 'Disponível'

WHERE r.id_reserva = NEW.id_reserva;

END IF;

END $$

DELIMITER ;

