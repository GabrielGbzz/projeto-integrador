CREATE DATABASE bibliotech;
USE bibliotech;

CREATE TABLE Cliente (
id_cliente INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR(50),
email VARCHAR(50),
endereco VARCHAR(99),
telefone VARCHAR(15)
);

CREATE TABLE Categoria (
id_categoria INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR(50),
descricao VARCHAR(100)
);

CREATE TABLE Autor (
id_autor INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR(50),
nacionalidade VARCHAR(50),
data_nascimento DATE
);

CREATE TABLE Livro (
id_livro INT AUTO_INCREMENT PRIMARY KEY,
titulo VARCHAR(100),
isbn VARCHAR(50),
ano_publicacao DATE,
tipo_emprestimo VARCHAR(1),

id_autor INT,
id_categoria INT,

FOREIGN KEY (id_autor)
REFERENCES Autor(id_autor),

FOREIGN KEY (id_categoria)
REFERENCES Categoria(id_categoria)
);

CREATE TABLE Exemplar (
id_exemplar INT AUTO_INCREMENT PRIMARY KEY,
codigo_exemplar VARCHAR(11),
estado_conservacao VARCHAR(30),
disponibilidade VARCHAR(20),

id_livro INT,

FOREIGN KEY (id_livro)
REFERENCES Livro(id_livro)
);

CREATE TABLE Emprestimo (
id_emprestimo INT AUTO_INCREMENT PRIMARY KEY,
data_emprestimo DATE,
data_prevista_devolucao DATE,
data_devolucao DATE,
tipo VARCHAR(20),

id_cliente INT,
id_exemplar INT,

FOREIGN KEY (id_cliente)
REFERENCES Cliente(id_cliente),
FOREIGN KEY (id_exemplar)
REFERENCES Exemplar(id_exemplar)
);

CREATE TABLE Multa (
id_multa INT AUTO_INCREMENT PRIMARY KEY,
valor DECIMAL(10,2),
data_multa DATE,
status_pagamento VARCHAR(20),

id_emprestimo INT,

FOREIGN KEY (id_emprestimo)
REFERENCES Emprestimo(id_emprestimo)
);

ALTER TABLE Cliente
ADD status_ativo BOOLEAN;

ALTER TABLE Categoria
ADD data_criacao DATETIME;

ALTER TABLE Autor
ADD observacoes VARCHAR(200);

ALTER TABLE Livro
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Exemplar
ADD data_registro DATE;

ALTER TABLE Emprestimo
ADD observacoes VARCHAR(200);

ALTER TABLE Multa
ADD data_pagamento DATE;

DELIMITER $$

CREATE PROCEDURE InserirCliente(

IN p_nome VARCHAR(50),
IN p_email VARCHAR(50),
IN p_endereco VARCHAR(99),
IN p_telefone VARCHAR(15)

)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE email=p_email) THEN

SELECT 'Cliente já cadastrado.' AS Mensagem;

ELSE

INSERT INTO Cliente(nome,email,endereco,telefone)
VALUES(p_nome,p_email,p_endereco,p_telefone);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirCategoria(

IN p_nome VARCHAR(50),
IN p_descricao VARCHAR(100)

)
BEGIN

IF EXISTS(SELECT * FROM Categoria WHERE nome=p_nome) THEN

SELECT 'Categoria já existe.';

ELSE

INSERT INTO Categoria(nome,descricao)
VALUES(p_nome,p_descricao);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirAutor(

IN p_nome VARCHAR(50),
IN p_nacionalidade VARCHAR(50),
IN p_data DATE

)
BEGIN

IF EXISTS(SELECT * FROM Autor WHERE nome=p_nome) THEN

SELECT 'Autor já cadastrado.';

ELSE

INSERT INTO Autor(nome,nacionalidade,data_nascimento)
VALUES(p_nome,p_nacionalidade,p_data);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirLivro(

IN p_titulo VARCHAR(100),
IN p_isbn VARCHAR(50),
IN p_ano DATE,
IN p_tipo VARCHAR(1),
IN p_autor INT,
IN p_categoria INT

)
BEGIN

IF EXISTS(SELECT * FROM Autor WHERE id_autor=p_autor)
AND EXISTS(SELECT * FROM Categoria WHERE id_categoria=p_categoria) THEN

INSERT INTO Livro
(titulo,isbn,ano_publicacao,tipo_emprestimo,id_autor,id_categoria)

VALUES
(p_titulo,p_isbn,p_ano,p_tipo,p_autor,p_categoria);

ELSE

SELECT 'Autor ou Categoria inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirExemplar(

IN p_codigo VARCHAR(11),
IN p_estado VARCHAR(30),
IN p_disponibilidade VARCHAR(20),
IN p_livro INT

)
BEGIN

IF EXISTS(SELECT * FROM Livro WHERE id_livro=p_livro) THEN

INSERT INTO Exemplar
(codigo_exemplar,estado_conservacao,disponibilidade,id_livro)

VALUES
(p_codigo,p_estado,p_disponibilidade,p_livro);

ELSE

SELECT 'Livro não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RealizarEmprestimo(

IN p_data DATE,
IN p_prevista DATE,
IN p_tipo VARCHAR(20),
IN p_cliente INT,
IN p_exemplar INT

)
BEGIN

DECLARE disponibilidade_atual VARCHAR(20);

SELECT disponibilidade
INTO disponibilidade_atual
FROM Exemplar
WHERE id_exemplar=p_exemplar;

IF disponibilidade_atual='Disponível' THEN

INSERT INTO Emprestimo
(data_emprestimo,data_prevista_devolucao,tipo,id_cliente,id_exemplar)

VALUES
(p_data,p_prevista,p_tipo,p_cliente,p_exemplar);

UPDATE Exemplar
SET disponibilidade='Emprestado'
WHERE id_exemplar=p_exemplar;

ELSE

SELECT 'Exemplar indisponível.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE GerarMulta(

IN p_valor DECIMAL(10,2),
IN p_data DATE,
IN p_emprestimo INT

)
BEGIN

IF EXISTS(SELECT * FROM Emprestimo WHERE id_emprestimo=p_emprestimo) THEN

INSERT INTO Multa
(valor,data_multa,status_pagamento,id_emprestimo)

VALUES
(p_valor,p_data,'Pendente',p_emprestimo);

ELSE

SELECT 'Empréstimo não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_emprestimo_exemplar
AFTER INSERT ON Emprestimo
FOR EACH ROW
BEGIN

UPDATE Exemplar
SET disponibilidade = 'Indisponível'
WHERE id_exemplar = NEW.id_exemplar;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_devolucao_exemplar
AFTER UPDATE ON Emprestimo
FOR EACH ROW
BEGIN

IF NEW.data_devolucao IS NOT NULL THEN

UPDATE Exemplar
SET disponibilidade = 'Disponível'
WHERE id_exemplar = NEW.id_exemplar;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_gerar_multa
AFTER UPDATE ON Emprestimo
FOR EACH ROW
BEGIN

IF NEW.data_devolucao > NEW.data_prevista_devolucao THEN

INSERT INTO Multa
(valor, data_multa, status_pagamento, id_emprestimo)

VALUES
(20.00, CURDATE(), 'Pendente', NEW.id_emprestimo);

END IF;

END $$

DELIMITER ;

