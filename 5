CREATE DATABASE autoprime;
USE autoprime;

CREATE TABLE Cliente (
id_Cliente INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR(50),
email VARCHAR(50),
senha VARCHAR(99),
CPF CHAR (20),

CONSTRAINT uc_email
UNIQUE (email),
CONSTRAINT uc_CPF
UNIQUE (CPF),
CONSTRAINT uc_senha
UNIQUE (senha)
);

CREATE TABLE Test (
id_test INT AUTO_INCREMENT PRIMARY KEY,
data DATE,
hora TIME,
id_cliente INT,
id_veiculo INT,

FOREIGN KEY (id_cliente)
REFERENCES Cliente(id_cliente)
);

CREATE TABLE Veiculo ( 
id_veiculo INT AUTO_INCREMENT PRIMARY KEY,
marca VARCHAR(50),
modelo VARCHAR(50),
ano DATE,
cor VARCHAR (50),
tipo VARCHAR (20),
preco DECIMAL,
status_venda VARCHAR (50)
);

CREATE TABLE Ordem (
id_ordem INT AUTO_INCREMENT PRIMARY KEY,
data_abertura DATE,
data_fechamento DATE,
descricao VARCHAR (50),
valor_total DECIMAL,
status VARCHAR (50),
id_cliente INT,
id_veiculo INT,
id_mecanico INT,

FOREIGN KEY (id_cliente)
REFERENCES Cliente(id_cliente),

FOREIGN KEY (id_veiculo)
REFERENCES Veiculo(id_veiculo),

FOREIGN KEY (id_mecanico)
REFERENCES Mecanico(id_mecanico)
);

CREATE TABLE Mecanico (
id_mecanico INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR (100),
especialidade VARCHAR(30),
telefone CHAR (20),

CONSTRAINT uc_telefone
UNIQUE (telefone)
);

CREATE TABLE Item_Ordem (
id_item INT AUTO_INCREMENT PRIMARY KEY,
quantidade INT,
valor DECIMAL,
id_ordem INT,
id_peca INT,

FOREIGN KEY (id_ordem)
REFERENCES Ordem(id_ordem),
FOREIGN KEY (id_peca)
REFERENCES peca(id_peca)
);

CREATE TABLE peca (
id_peca INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR (50),
descricao VARCHAR (50),
preco DECIMAL,
quantidade VARCHAR (500)
);

ALTER TABLE Cliente
ADD status_ativo BOOLEAN;

ALTER TABLE Veiculo
ADD data_cadastro DATETIME;

ALTER TABLE Test
ADD observacoes VARCHAR(200);

ALTER TABLE Mecanico
ADD status_ativo BOOLEAN;

ALTER TABLE Ordem
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Peca
ADD fornecedor VARCHAR(100);

ALTER TABLE Item_Ordem
ADD data_registro DATE;

DELIMITER $$

CREATE PROCEDURE InserirCliente(

IN p_nome VARCHAR(50),
IN p_email VARCHAR(50),
IN p_senha VARCHAR(99),
IN p_cpf CHAR(20)

)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE email=p_email) THEN

SELECT 'Cliente já cadastrado.';

ELSE

INSERT INTO Cliente(nome,email,senha,CPF)
VALUES(p_nome,p_email,p_senha,p_cpf);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirVeiculo(

IN p_marca VARCHAR(50),
IN p_modelo VARCHAR(50),
IN p_ano DATE,
IN p_cor VARCHAR(50),
IN p_tipo VARCHAR(20),
IN p_preco DECIMAL(10,2)

)
BEGIN

IF p_preco > 0 THEN

INSERT INTO Veiculo
(marca,modelo,ano,cor,tipo,preco,status_venda)

VALUES
(p_marca,p_modelo,p_ano,p_cor,p_tipo,p_preco,'Disponível');

ELSE

SELECT 'Preço inválido.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE AgendarTestDrive(

IN p_data DATE,
IN p_hora TIME,
IN p_cliente INT,
IN p_veiculo INT

)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE id_cliente=p_cliente)
AND EXISTS(SELECT * FROM Veiculo WHERE id_veiculo=p_veiculo) THEN

INSERT INTO Test(data,hora,id_cliente,id_veiculo)

VALUES
(p_data,p_hora,p_cliente,p_veiculo);

ELSE

SELECT 'Cliente ou veículo inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirMecanico(

IN p_nome VARCHAR(100),
IN p_especialidade VARCHAR(30),
IN p_telefone CHAR(20)

)
BEGIN

IF EXISTS(SELECT * FROM Mecanico WHERE telefone=p_telefone) THEN

SELECT 'Telefone já cadastrado.';

ELSE

INSERT INTO Mecanico
(nome,especialidade,telefone)

VALUES
(p_nome,p_especialidade,p_telefone);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE CriarOrdem(

IN p_data DATE,
IN p_descricao VARCHAR(50),
IN p_cliente INT,
IN p_veiculo INT,
IN p_mecanico INT

)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE id_cliente=p_cliente)
AND EXISTS(SELECT * FROM Veiculo WHERE id_veiculo=p_veiculo)
AND EXISTS(SELECT * FROM Mecanico WHERE id_mecanico=p_mecanico) THEN

INSERT INTO Ordem
(data_abertura,descricao,status,id_cliente,id_veiculo,id_mecanico)

VALUES
(p_data,p_descricao,'Aberta',p_cliente,p_veiculo,p_mecanico);

ELSE

SELECT 'Dados inválidos.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirPeca(

IN p_nome VARCHAR(50),
IN p_descricao VARCHAR(50),
IN p_preco DECIMAL(10,2),
IN p_quantidade VARCHAR(500)

)
BEGIN

IF p_preco > 0 THEN

INSERT INTO Peca
(nome,descricao,preco,quantidade)

VALUES
(p_nome,p_descricao,p_preco,p_quantidade);

ELSE

SELECT 'Preço inválido.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE AdicionarItemOrdem(

IN p_quantidade VARCHAR(50),
IN p_valor DECIMAL(10,2),
IN p_ordem INT,
IN p_peca INT

)
BEGIN

IF EXISTS(SELECT * FROM Ordem WHERE id_ordem=p_ordem)
AND EXISTS(SELECT * FROM Peca WHERE id_peca=p_peca) THEN

INSERT INTO Item_Ordem
(quantidade,valor,id_ordem,id_peca)

VALUES
(p_quantidade,p_valor,p_ordem,p_peca);

ELSE

SELECT 'Ordem ou peça inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_reservar_veiculo
AFTER INSERT ON Test
FOR EACH ROW
BEGIN

UPDATE Veiculo
SET status_venda = 'Reservado para Test Drive'
WHERE id_veiculo = NEW.id_veiculo;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_baixar_estoque_peca
AFTER INSERT ON Item_Ordem
FOR EACH ROW
BEGIN

UPDATE Peca
SET quantidade = quantidade - NEW.quantidade
WHERE id_peca = NEW.id_peca;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_verificar_estoque_peca
BEFORE INSERT ON Item_Ordem
FOR EACH ROW
BEGIN

DECLARE v_quantidade INT;

SELECT quantidade
INTO v_quantidade
FROM Peca
WHERE id_peca = NEW.id_peca;

IF NEW.quantidade > v_quantidade THEN

SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Quantidade em estoque insuficiente.';

END IF;

END $$

