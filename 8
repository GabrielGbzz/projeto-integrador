CREATE DATABASE IronFit;
USE IronFit;

CREATE TABLE Plano_Subscricao (
    id_plano INT AUTO_INCREMENT PRIMARY KEY,
    nome_plano VARCHAR(100),
    valor_mensal DECIMAL(10,2),
    duracao INT,
    beneficios TEXT
);

CREATE TABLE Membro (
    id_membro INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    data_nascimento DATE,
    email VARCHAR(100) UNIQUE,
    telefone VARCHAR(20),
    endereco VARCHAR(150),
    id_plano INT,

    FOREIGN KEY (id_plano)
    REFERENCES Plano_Subscricao(id_plano)
);

CREATE TABLE Avaliacao_Fisica (
    id_avaliacao INT AUTO_INCREMENT PRIMARY KEY,
    data_avaliacao DATE,
    peso DECIMAL(5,2),
    altura DECIMAL(4,2),
    imc DECIMAL(5,2),
    observacoes TEXT,
    id_membro INT,

    FOREIGN KEY (id_membro)
    REFERENCES Membro(id_membro)
);

CREATE TABLE PersonalTrainer (
    id_trainer INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    especialidade VARCHAR(100),
    telefone VARCHAR(20),
    email VARCHAR(100)
);

CREATE TABLE Treinamento (
    id_treinamento INT AUTO_INCREMENT PRIMARY KEY,
    data_inicio DATE,
    data_fim DATE,
    objetivo TEXT,
    id_membro INT,
    id_trainer INT,

    FOREIGN KEY (id_membro)
    REFERENCES Membro(id_membro),

    FOREIGN KEY (id_trainer)
    REFERENCES PersonalTrainer(id_trainer)
);

CREATE TABLE Aula_Grupo (
    id_aula INT AUTO_INCREMENT PRIMARY KEY,
    nome_aula VARCHAR(100),
    horario TIME,
    capacidade INT,
    nivel VARCHAR(30)
);

CREATE TABLE Marcacao_Aula (
    id_marcacao INT AUTO_INCREMENT PRIMARY KEY,
    data_marcacao DATE,
    presenca BOOLEAN,
    id_membro INT,
    id_aula INT,

    FOREIGN KEY (id_membro)
    REFERENCES Membro(id_membro),

    FOREIGN KEY (id_aula)
    REFERENCES Aula_Grupo(id_aula)
);

ALTER TABLE Plano_Subscricao
ADD status_ativo BOOLEAN DEFAULT TRUE;

ALTER TABLE Membro
ADD data_criacao DATE;

ALTER TABLE Avaliacao_Fisica
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE PersonalTrainer
ADD status_ativo BOOLEAN DEFAULT TRUE;

ALTER TABLE Treinamento
ADD observacoes_internas TEXT;

ALTER TABLE Aula_Grupo
ADD sala VARCHAR(50);

ALTER TABLE Marcacao_Aula
ADD data_cancelamento DATE;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarPlano(
IN p_nome VARCHAR(100),
IN p_valor DECIMAL(10,2),
IN p_duracao INT,
IN p_beneficios TEXT
)
BEGIN

IF p_valor > 0 THEN

INSERT INTO Plano_Subscricao(nome_plano,valor_mensal,duracao,beneficios)
VALUES(p_nome,p_valor,p_duracao,p_beneficios);

ELSE

SELECT 'Valor inválido' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarMembro(
IN p_nome VARCHAR(100),
IN p_data DATE,
IN p_email VARCHAR(100),
IN p_tel VARCHAR(20),
IN p_endereco VARCHAR(150),
IN p_plano INT
)

BEGIN

DECLARE existe INT;

SELECT COUNT(*) INTO existe
FROM Plano_Subscricao
WHERE id_plano=p_plano;

IF existe>0 THEN

INSERT INTO Membro
(nome,data_nascimento,email,telefone,endereco,id_plano)
VALUES
(p_nome,p_data,p_email,p_tel,p_endereco,p_plano);

ELSE

SELECT 'Plano inexistente' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_Avaliacao(
IN p_data DATE,
IN p_peso DECIMAL(5,2),
IN p_altura DECIMAL(4,2),
IN p_obs TEXT,
IN p_membro INT
)

BEGIN

DECLARE v_imc DECIMAL(5,2);

SET v_imc=p_peso/(p_altura*p_altura);

INSERT INTO Avaliacao_Fisica
(data_avaliacao,peso,altura,imc,observacoes,id_membro)

VALUES
(p_data,p_peso,p_altura,v_imc,p_obs,p_membro);

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarTrainer(
IN p_nome VARCHAR(100),
IN p_esp VARCHAR(100),
IN p_tel VARCHAR(20),
IN p_email VARCHAR(100)
)

BEGIN

IF EXISTS(SELECT * FROM PersonalTrainer
WHERE email=p_email)

THEN

SELECT 'Email já existe';

ELSE

INSERT INTO PersonalTrainer
(nome,especialidade,telefone,email)

VALUES
(p_nome,p_esp,p_tel,p_email);

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_Treinamento(
IN p_inicio DATE,
IN p_fim DATE,
IN p_obj TEXT,
IN p_membro INT,
IN p_trainer INT
)

BEGIN

IF EXISTS
(SELECT * FROM PersonalTrainer
WHERE id_trainer=p_trainer)

THEN

INSERT INTO Treinamento
(data_inicio,data_fim,objetivo,id_membro,id_trainer)

VALUES
(p_inicio,p_fim,p_obj,p_membro,p_trainer);

ELSE

SELECT 'Trainer não encontrado';

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_Aula(
IN p_nome VARCHAR(100),
IN p_hora TIME,
IN p_capacidade INT,
IN p_nivel VARCHAR(30)
)

BEGIN

IF p_capacidade>0 THEN

INSERT INTO Aula_Grupo
(nome_aula,horario,capacidade,nivel)

VALUES
(p_nome,p_hora,p_capacidade,p_nivel);

ELSE

SELECT 'Capacidade inválida';

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_Marcacao(
IN p_data DATE,
IN p_presenca BOOLEAN,
IN p_membro INT,
IN p_aula INT
)

BEGIN

IF EXISTS(SELECT * FROM Membro WHERE id_membro=p_membro)
AND EXISTS(SELECT * FROM Aula_Grupo WHERE id_aula=p_aula)

THEN

INSERT INTO Marcacao_Aula
(data_marcacao,presenca,id_membro,id_aula)

VALUES
(p_data,p_presenca,p_membro,p_aula);

ELSE

SELECT 'Membro ou Aula inexistente';

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_calcular_imc
BEFORE INSERT ON Avaliacao_Fisica
FOR EACH ROW
BEGIN

SET NEW.imc = NEW.peso / (NEW.altura * NEW.altura);

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_presenca_padrao
BEFORE INSERT ON Marcacao_Aula
FOR EACH ROW
BEGIN

SET NEW.presenca = FALSE;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_verificar_plano
BEFORE INSERT ON Treinamento
FOR EACH ROW
BEGIN

DECLARE v_plano INT;

SELECT id_plano
INTO v_plano
FROM Membro
WHERE id_membro = NEW.id_membro;

IF v_plano IS NULL THEN

SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'O membro não possui plano de subscrição.';

END IF;

END $$

DELIMITER ;

