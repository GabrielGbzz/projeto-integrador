CREATE DATABASE MedPet;
USE MedPet;


CREATE TABLE Cliente (
    id_cliente INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    email VARCHAR(100),
    endereco VARCHAR(150)
);


CREATE TABLE Animal (
    id_animal INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    especie VARCHAR(50),
    raca VARCHAR(50),
    sexo CHAR(1),
    data_nascimento DATE,
    peso DECIMAL(5,2),
    id_cliente INT,
    FOREIGN KEY (id_cliente)
	REFERENCES Cliente(id_cliente)
);


CREATE TABLE Consulta (
    id_consulta INT AUTO_INCREMENT PRIMARY KEY,
    data_consulta DATE,
    hora TIME,
    diagnostico VARCHAR(255),
    observacoes TEXT,
    id_animal INT,
    FOREIGN KEY (id_animal)
	REFERENCES Animal(id_animal)
);


CREATE TABLE Internamento (
    id_internamento INT AUTO_INCREMENT PRIMARY KEY,
    data_entrada DATE,
    data_saida DATE,
    motivo VARCHAR(150),
    quarto VARCHAR(20),
    status VARCHAR(30),
    id_animal INT,
    FOREIGN KEY (id_animal)
	REFERENCES Animal(id_animal)
);


CREATE TABLE Historico_Medico (
    id_historico INT AUTO_INCREMENT PRIMARY KEY,
    tipo_registro VARCHAR(50),
    descricao TEXT,
    data_registro DATE,
    id_animal INT,
    FOREIGN KEY (id_animal)
	REFERENCES Animal(id_animal)
);


CREATE TABLE Fatura (
    id_fatura INT AUTO_INCREMENT PRIMARY KEY,
    data_emissao DATE,
    valor_total DECIMAL(10,2),
    forma_pagamento VARCHAR(50),
    status VARCHAR(30),
    id_dono INT,
    FOREIGN KEY (id_dono)
    REFERENCES Cliente(id_cliente)
);


CREATE TABLE Item_Fatura (
    id_item INT AUTO_INCREMENT PRIMARY KEY,
    descricao_servico VARCHAR(100),
    valor DECIMAL(10,2),
    quantidade INT,
    id_fatura INT,
    FOREIGN KEY (id_fatura)
	REFERENCES Fatura(id_fatura)
);

ALTER TABLE Cliente
ADD status_ativo BOOLEAN;

ALTER TABLE Animal
ADD status_ativo BOOLEAN;

ALTER TABLE Consulta
ADD data_criacao DATETIME;

ALTER TABLE Internamento
ADD observacoes_internas VARCHAR(255);

ALTER TABLE Historico_Medico
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Fatura
ADD data_criacao DATETIME;

ALTER TABLE Item_Fatura
ADD observacoes VARCHAR(150);

DELIMITER $$

CREATE PROCEDURE InserirCliente(
IN p_nome VARCHAR(100),
IN p_email VARCHAR(100),
IN p_endereco VARCHAR(150)
)
BEGIN

IF EXISTS (SELECT * FROM Cliente WHERE email=p_email) THEN
SELECT 'Cliente já existe.' AS Mensagem;
ELSE
INSERT INTO Cliente(nome,email,endereco)
VALUES(p_nome,p_email,p_endereco);
END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirAnimal(
IN p_nome VARCHAR(100),
IN p_especie VARCHAR(50),
IN p_raca VARCHAR(50),
IN p_cliente INT
)
BEGIN

IF EXISTS (SELECT * FROM Cliente WHERE id_cliente=p_cliente) THEN

INSERT INTO Animal(nome,especie,raca,id_cliente)
VALUES(p_nome,p_especie,p_raca,p_cliente);

ELSE

SELECT 'Cliente não encontrado.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE MarcarConsulta(
IN p_data DATE,
IN p_hora TIME,
IN p_diag VARCHAR(255),
IN p_animal INT
)
BEGIN

IF EXISTS(SELECT * FROM Animal WHERE id_animal=p_animal) THEN

INSERT INTO Consulta(data_consulta,hora,diagnostico,id_animal)
VALUES(p_data,p_hora,p_diag,p_animal);

ELSE

SELECT 'Animal inexistente.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InternarAnimal(
IN p_data DATE,
IN p_motivo VARCHAR(150),
IN p_quarto VARCHAR(20),
IN p_animal INT
)
BEGIN

IF EXISTS(SELECT * FROM Animal WHERE id_animal=p_animal) THEN

INSERT INTO Internamento
(data_entrada,motivo,quarto,status,id_animal)
VALUES(p_data,p_motivo,p_quarto,'Internado',p_animal);

ELSE

SELECT 'Animal não existe.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE AdicionarHistorico(
IN p_tipo VARCHAR(50),
IN p_desc TEXT,
IN p_data DATE,
IN p_animal INT
)
BEGIN

IF EXISTS(SELECT * FROM Animal WHERE id_animal=p_animal) THEN

INSERT INTO Historico_Medico
(tipo_registro,descricao,data_registro,id_animal)
VALUES(p_tipo,p_desc,p_data,p_animal);

ELSE

SELECT 'Animal não encontrado.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE CriarFatura(
IN p_data DATE,
IN p_valor DECIMAL(10,2),
IN p_pagamento VARCHAR(50),
IN p_cliente INT
)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE id_cliente=p_cliente) THEN

INSERT INTO Fatura
(data_emissao,valor_total,forma_pagamento,status,id_dono)
VALUES(p_data,p_valor,p_pagamento,'Pendente',p_cliente);

ELSE

SELECT 'Cliente inexistente.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE AdicionarItemFatura(
IN p_desc VARCHAR(100),
IN p_valor DECIMAL(10,2),
IN p_qtd INT,
IN p_fatura INT
)
BEGIN

DECLARE total DECIMAL(10,2);

IF EXISTS(SELECT * FROM Fatura WHERE id_fatura=p_fatura) THEN

SET total = p_valor * p_qtd;

INSERT INTO Item_Fatura
(descricao_servico,valor,quantidade,id_fatura)
VALUES(p_desc,total,p_qtd,p_fatura);

ELSE

SELECT 'Fatura não encontrada.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_historico_consulta
AFTER INSERT ON Consulta
FOR EACH ROW
BEGIN

INSERT INTO Historico_Medico
(tipo_registro, descricao, data_registro, id_animal)

VALUES
('Consulta',
NEW.diagnostico,
NEW.data_consulta,
NEW.id_animal);

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_status_fatura
AFTER INSERT ON Item_Fatura
FOR EACH ROW
BEGIN

UPDATE Fatura
SET status = 'Pendente'
WHERE id_fatura = NEW.id_fatura;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_verificar_datas
BEFORE INSERT ON Internamento
FOR EACH ROW
BEGIN

IF NEW.data_saida IS NOT NULL
AND NEW.data_saida < NEW.data_entrada THEN

SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'A data de saída não pode ser anterior à data de entrada.';

END IF;

END $$

DELIMITER ;

