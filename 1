CREATE DATABASE EcoStyle;
USE EcoStyle;

CREATE TABLE Cliente (
    id_cliente INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    email VARCHAR(100),
    endereco VARCHAR(255),
    
    CONSTRAINT uc_endereco
    UNIQUE (endereco)
);

CREATE TABLE Produto (
    id_produto INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    descricao TEXT,
    preco DECIMAL(10,2),
    categoria VARCHAR(50),
    material_ecologico BOOLEAN,
    stock INT
);

CREATE TABLE Fornecedor (
    id_fornecedor INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    empresa VARCHAR(100),
    telefone VARCHAR(20),
    email VARCHAR(100),
    tipo_material_reciclado VARCHAR(100)
);

CREATE TABLE Pedido (
    id_pedido INT AUTO_INCREMENT PRIMARY KEY,
    data_pedido DATE,
    valor_total DECIMAL(10,2),
    status VARCHAR(50),
    id_cliente INT,

    FOREIGN KEY (id_cliente)
	REFERENCES Cliente(id_cliente)
       
);

CREATE TABLE Item_Pedido (
    id_item INT AUTO_INCREMENT PRIMARY KEY,
    quantidade INT NOT NULL,
    preco_unitario DECIMAL(10,2) NOT NULL,
    id_pedido INT NOT NULL,
    id_produto INT NOT NULL,

    FOREIGN KEY (id_pedido)
	REFERENCES Pedido(id_pedido),
        
    FOREIGN KEY (id_produto)
	REFERENCES Produto(id_produto)
        
        
);

CREATE TABLE Entrega (
    id_entrega INT AUTO_INCREMENT PRIMARY KEY,
    data_envio DATE,
    data_entrega DATE,
    transportadora VARCHAR(100),
    carbono_neutro BOOLEAN,
    id_pedido INT,

    FOREIGN KEY (id_pedido)
	REFERENCES Pedido(id_pedido)
        
);

CREATE TABLE Devolucao (
    id_devolucao INT AUTO_INCREMENT PRIMARY KEY,
    data_devolucao DATE,
    motivo VARCHAR(255),
    status VARCHAR(50),
    id_pedido INT,

    FOREIGN KEY (id_pedido)
	REFERENCES Pedido(id_pedido)
      
);

ALTER TABLE Cliente
ADD status_ativo BOOLEAN DEFAULT TRUE;

ALTER TABLE Produto
ADD data_criacao DATETIME DEFAULT CURRENT_TIMESTAMP;

ALTER TABLE Fornecedor
ADD observacoes VARCHAR(200);

ALTER TABLE Pedido
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Item_Pedido
ADD observacoes VARCHAR(150);

ALTER TABLE Entrega
ADD data_criacao DATETIME DEFAULT CURRENT_TIMESTAMP;

ALTER TABLE Devolucao
ADD usuario_alteracao VARCHAR(50);


DELIMITER $$

CREATE PROCEDURE InserirCliente(

IN p_nome VARCHAR(100),
IN p_email VARCHAR(100),
IN p_endereco VARCHAR(150)

)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE email=p_email) THEN

SELECT 'Cliente já existe.' AS Mensagem;

ELSE

INSERT INTO Cliente(nome,email,endereco)
VALUES(p_nome,p_email,p_endereco);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirProduto(

IN p_nome VARCHAR(100),
IN p_desc TEXT,
IN p_preco DECIMAL(10,2),
IN p_categoria VARCHAR(50)

)
BEGIN

IF p_preco > 0 THEN

INSERT INTO Produto(nome,descricao,preco,categoria)
VALUES(p_nome,p_desc,p_preco,p_categoria);

ELSE

SELECT 'Preço inválido.' AS Mensagem;

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirFornecedor(

IN p_nome VARCHAR(100),
IN p_empresa VARCHAR(100),
IN p_email VARCHAR(100)

)
BEGIN

IF EXISTS(SELECT * FROM Fornecedor WHERE email=p_email) THEN

SELECT 'Fornecedor já existe.';

ELSE

INSERT INTO Fornecedor(nome,empresa,email)
VALUES(p_nome,p_empresa,p_email);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE CriarPedido(

IN p_data DATE,
IN p_total DECIMAL(10,2),
IN p_cliente INT

)
BEGIN

IF EXISTS(SELECT * FROM Cliente WHERE id_cliente=p_cliente) THEN

INSERT INTO Pedido(data_pedido,valor_total,status,id_cliente)
VALUES(p_data,p_total,'Pendente',p_cliente);

ELSE

SELECT 'Cliente não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE AdicionarItem(

IN p_quantidade INT,
IN p_preco DECIMAL(10,2),
IN p_pedido INT,
IN p_produto INT

)
BEGIN

DECLARE estoque INT;

SELECT stock
INTO estoque
FROM Produto
WHERE id_produto=p_produto;

IF estoque >= p_quantidade THEN

INSERT INTO Item_Pedido
(quantidade,preco_unitario,id_pedido,id_produto)
VALUES(p_quantidade,p_preco,p_pedido,p_produto);

UPDATE Produto
SET stock = stock - p_quantidade
WHERE id_produto=p_produto;

ELSE

SELECT 'Stock insuficiente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RegistrarEntrega(

IN p_envio DATE,
IN p_entrega DATE,
IN p_transportadora VARCHAR(100),
IN p_pedido INT

)
BEGIN

IF EXISTS(SELECT * FROM Pedido WHERE id_pedido=p_pedido) THEN

INSERT INTO Entrega
(data_envio,data_entrega,transportadora,carbono_neutro,id_pedido)

VALUES
(p_envio,p_entrega,p_transportadora,TRUE,p_pedido);

ELSE

SELECT 'Pedido não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RegistrarDevolucao(

IN p_data DATE,
IN p_motivo VARCHAR(255),
IN p_pedido INT

)
BEGIN

IF EXISTS(SELECT * FROM Pedido WHERE id_pedido=p_pedido) THEN

INSERT INTO Devolucao
(data_devolucao,motivo,status,id_pedido)

VALUES
(p_data,p_motivo,'Em análise',p_pedido);

ELSE

SELECT 'Pedido inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_baixar_estoque
AFTER INSERT ON Item_Pedido
FOR EACH ROW
BEGIN

UPDATE Produto
SET stock = stock - NEW.quantidade
WHERE id_produto = NEW.id_produto;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_verificar_estoque
BEFORE INSERT ON Item_Pedido
FOR EACH ROW
BEGIN

DECLARE v_stock INT;

SELECT stock
INTO v_stock
FROM Produto
WHERE id_produto = NEW.id_produto;

IF NEW.quantidade > v_stock THEN

SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Estoque insuficiente para realizar a venda.';

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_atualizar_status_pedido
AFTER INSERT ON Entrega
FOR EACH ROW
BEGIN

UPDATE Pedido
SET status = 'Enviado'
WHERE id_pedido = NEW.id_pedido;

END $$

DELIMITER ;

