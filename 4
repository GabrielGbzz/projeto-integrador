CREATE DATABASE tunestream;
USE tunestream;

CREATE TABLE Artista (
id_artista INT AUTO_INCREMENT PRIMARY KEY,
nome_artistico VARCHAR(50),
pais VARCHAR(50),
biografia VARCHAR(99),

CONSTRAINT uc_biografia
UNIQUE (biografia)
);

CREATE TABLE Album (
id_album INT AUTO_INCREMENT PRIMARY KEY,
titulo VARCHAR(50),
data_lancamento DATE,
genero VARCHAR(50),
id_artista INT,

FOREIGN KEY (id_artista)
REFERENCES Artista(id_artista)
);

CREATE TABLE Audio ( 
id_audio INT AUTO_INCREMENT PRIMARY KEY,
titulo VARCHAR(50),
duracao VARCHAR(50),
tipo VARCHAR (50),
numero_reproducoes VARCHAR (50),
id_album INT,

FOREIGN KEY (id_album)
REFERENCES Album(id_album)
);

CREATE TABLE Royalty (
id_royalty INT AUTO_INCREMENT PRIMARY KEY,
valor DECIMAL (12,00),
data_pagamento DATE,
id_artista INT,
id_audio INT,

FOREIGN KEY (id_artista)
REFERENCES Artista(id_artista),

FOREIGN KEY (id_audio)
REFERENCES Audio(id_audio)
);

CREATE TABLE Historico (
id_historico INT AUTO_INCREMENT PRIMARY KEY,
data_reproducao DATE,
tempo_ouvido VARCHAR(30),

id_audio INT,
id_utilizador INT,

FOREIGN KEY (id_utilizador)
REFERENCES Utilizador(id_utilizador),
FOREIGN KEY (id_audio)
REFERENCES Audio(id_audio)
);

CREATE TABLE Utilizador (
id_utilizador INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR (50),
email VARCHAR (50),
senha VARCHAR (50),
tipo VARCHAR(20),
data_registro DATE,

CONSTRAINT uc_email
UNIQUE (email),
CONSTRAINT uc_senha
UNIQUE (senha)
);

CREATE TABLE Playlist (
id_playlist INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR (100),
data_criacao DATE,

id_utilizador INT,

FOREIGN KEY (id_utilizador)
REFERENCES Utilizador(id_utilizador)
);

ALTER TABLE Artista
ADD status_ativo BOOLEAN;

ALTER TABLE Album
ADD data_criacao DATETIME;

ALTER TABLE Audio
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Royalty
ADD observacoes VARCHAR(200);

ALTER TABLE Utilizador
ADD status_ativo BOOLEAN;

ALTER TABLE Historico
ADD dispositivo VARCHAR(50);

ALTER TABLE Playlist
ADD descricao VARCHAR(150);

DELIMITER $$

CREATE PROCEDURE InserirArtista(

IN p_nome VARCHAR(50),
IN p_pais VARCHAR(50),
IN p_biografia VARCHAR(99)

)
BEGIN

IF EXISTS(SELECT * FROM Artista WHERE biografia=p_biografia) THEN

SELECT 'Artista já cadastrado.';

ELSE

INSERT INTO Artista(nome_artistico,pais,biografia)
VALUES(p_nome,p_pais,p_biografia);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirAlbum(

IN p_titulo VARCHAR(50),
IN p_data DATE,
IN p_genero VARCHAR(50),
IN p_artista INT

)
BEGIN

IF EXISTS(SELECT * FROM Artista WHERE id_artista=p_artista) THEN

INSERT INTO Album
(titulo,data_lancamento,genero,id_artista)

VALUES
(p_titulo,p_data,p_genero,p_artista);

ELSE

SELECT 'Artista não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirAudio(

IN p_titulo VARCHAR(50),
IN p_duracao VARCHAR(50),
IN p_tipo VARCHAR(50),
IN p_album INT

)
BEGIN

IF EXISTS(SELECT * FROM Album WHERE id_album=p_album) THEN

INSERT INTO Audio
(titulo,duracao,tipo,numero_reproducoes,id_album)

VALUES
(p_titulo,p_duracao,p_tipo,'0',p_album);

ELSE

SELECT 'Álbum não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RegistrarRoyalty(

IN p_valor DECIMAL(12,2),
IN p_data DATE,
IN p_artista INT,
IN p_audio INT

)
BEGIN

IF EXISTS(SELECT * FROM Artista WHERE id_artista=p_artista)
AND EXISTS(SELECT * FROM Audio WHERE id_audio=p_audio) THEN

INSERT INTO Royalty
(valor,data_pagamento,id_artista,id_audio)

VALUES
(p_valor,p_data,p_artista,p_audio);

ELSE

SELECT 'Artista ou áudio inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirUtilizador(

IN p_nome VARCHAR(50),
IN p_email VARCHAR(50),
IN p_senha VARCHAR(50),
IN p_tipo VARCHAR(20),
IN p_data DATE

)
BEGIN

IF EXISTS(SELECT * FROM Utilizador WHERE email=p_email) THEN

SELECT 'Email já cadastrado.';

ELSE

INSERT INTO Utilizador
(nome,email,senha,tipo,data_registro)

VALUES
(p_nome,p_email,p_senha,p_tipo,p_data);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RegistrarHistorico(

IN p_data DATE,
IN p_tempo VARCHAR(30),
IN p_audio INT,
IN p_utilizador INT

)
BEGIN

IF EXISTS(SELECT * FROM Audio WHERE id_audio=p_audio)
AND EXISTS(SELECT * FROM Utilizador WHERE id_utilizador=p_utilizador) THEN

INSERT INTO Historico
(data_reproducao,tempo_ouvido,id_audio,id_utilizador)

VALUES
(p_data,p_tempo,p_audio,p_utilizador);

UPDATE Audio
SET numero_reproducoes = numero_reproducoes + 1
WHERE id_audio=p_audio;

ELSE

SELECT 'Áudio ou utilizador inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE CriarPlaylist(

IN p_nome VARCHAR(100),
IN p_data DATE,
IN p_utilizador INT

)
BEGIN

IF EXISTS(SELECT * FROM Utilizador WHERE id_utilizador=p_utilizador) THEN

INSERT INTO Playlist
(nome,data_criacao,id_utilizador)

VALUES
(p_nome,p_data,p_utilizador);

ELSE

SELECT 'Utilizador não encontrado.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_incrementar_reproducoes
AFTER INSERT ON Historico
FOR EACH ROW
BEGIN

UPDATE Audio
SET numero_reproducoes = numero_reproducoes + 1
WHERE id_audio = NEW.id_audio;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_playlist_padrao
AFTER INSERT ON Utilizador
FOR EACH ROW
BEGIN

INSERT INTO Playlist
(nome, data_criacao, id_utilizador)

VALUES
('Favoritas', CURDATE(), NEW.id_utilizador);

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_royalty_reproducao
AFTER INSERT ON Historico
FOR EACH ROW
BEGIN

INSERT INTO Royalty
(valor, data_pagamento, id_artista, id_audio)

SELECT
0.05,
CURDATE(),
a.id_artista,
NEW.id_audio
FROM Audio au
JOIN Album al
ON au.id_album = al.id_album
JOIN Artista a
ON al.id_artista = a.id_artista
WHERE au.id_audio = NEW.id_audio;

END $$

DELIMITER ;

