CREATE DATABASE LogisTruck;
USE LogisTruck;

CREATE TABLE Caminhao(
id_caminhao INT AUTO_INCREMENT PRIMARY KEY,
placa VARCHAR(10),
modelo VARCHAR(50),
ano INT,
capacidade_carga DECIMAL(10,2),
status VARCHAR(30)
);

CREATE TABLE Motorista(
id_motorista INT AUTO_INCREMENT PRIMARY KEY,
nome VARCHAR(100),
cpf VARCHAR(14),
telefone VARCHAR(20),
cnh VARCHAR(20)
);

CREATE TABLE Cliente_B2B(
id_cliente INT AUTO_INCREMENT PRIMARY KEY,
razao_social VARCHAR(100),
cnpj VARCHAR(18),
telefone VARCHAR(20),
endereco VARCHAR(150),
email VARCHAR(100)
);

CREATE TABLE Rota_Entrega(
id_rota INT AUTO_INCREMENT PRIMARY KEY,
origem VARCHAR(100),
destino VARCHAR(100),
distancia_km DECIMAL(10,2),
data_entrega DATE,
id_caminhao INT,
id_motorista INT,
id_cliente INT,

FOREIGN KEY(id_caminhao)
REFERENCES Caminhao(id_caminhao),

FOREIGN KEY(id_motorista)
REFERENCES Motorista(id_motorista),

FOREIGN KEY(id_cliente)
REFERENCES Cliente_B2B(id_cliente)
);

CREATE TABLE Carga(
id_carga INT AUTO_INCREMENT PRIMARY KEY,
descricao VARCHAR(100),
peso DECIMAL(10,2),
tipo_carga VARCHAR(50),
id_rota INT,

FOREIGN KEY(id_rota)
REFERENCES Rota_Entrega(id_rota)
);

CREATE TABLE Manutencao(
id_manutencao INT AUTO_INCREMENT PRIMARY KEY,
data_manutencao DATE,
tipo VARCHAR(50),
custo DECIMAL(10,2),
descricao TEXT,
id_caminhao INT,

FOREIGN KEY(id_caminhao)
REFERENCES Caminhao(id_caminhao)
);

CREATE TABLE Consumo_Combustivel(
id_consumo INT AUTO_INCREMENT PRIMARY KEY,
data_abastecimento DATE,
litros DECIMAL(10,2),
valor DECIMAL(10,2),
km_atual INT,
id_caminhao INT,

FOREIGN KEY(id_caminhao)
REFERENCES Caminhao(id_caminhao)
);

ALTER TABLE Caminhao
ADD data_cadastro DATE;

ALTER TABLE Motorista
ADD status_ativo BOOLEAN DEFAULT TRUE;

ALTER TABLE Cliente_B2B
ADD observacoes TEXT;

ALTER TABLE Rota_Entrega
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Carga
ADD data_cadastro DATE;

ALTER TABLE Manutencao
ADD status_servico VARCHAR(30);

ALTER TABLE Consumo_Combustivel
ADD observacao TEXT;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarCaminhao(
IN p_placa VARCHAR(10),
IN p_modelo VARCHAR(50),
IN p_ano INT,
IN p_capacidade DECIMAL(10,2),
IN p_status VARCHAR(30)
)
BEGIN

IF EXISTS(SELECT * FROM Caminhao WHERE placa=p_placa) THEN

SELECT 'Placa já cadastrada.' AS Mensagem;

ELSE

INSERT INTO Caminhao
(placa,modelo,ano,capacidade_carga,status)
VALUES
(p_placa,p_modelo,p_ano,p_capacidade,p_status);

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarMotorista(
IN p_nome VARCHAR(100),
IN p_cpf VARCHAR(14),
IN p_telefone VARCHAR(20),
IN p_cnh VARCHAR(20)
)
BEGIN

IF EXISTS(SELECT * FROM Motorista WHERE cpf=p_cpf) THEN

SELECT 'CPF já cadastrado.' AS Mensagem;

ELSE

INSERT INTO Motorista
(nome,cpf,telefone,cnh)

VALUES
(p_nome,p_cpf,p_telefone,p_cnh);

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarCliente(
IN p_razao VARCHAR(100),
IN p_cnpj VARCHAR(18),
IN p_tel VARCHAR(20),
IN p_endereco VARCHAR(150),
IN p_email VARCHAR(100)
)
BEGIN

IF EXISTS(SELECT * FROM Cliente_B2B WHERE cnpj=p_cnpj) THEN

SELECT 'CNPJ já cadastrado.' AS Mensagem;

ELSE

INSERT INTO Cliente_B2B
(razao_social,cnpj,telefone,endereco,email)

VALUES
(p_razao,p_cnpj,p_tel,p_endereco,p_email);

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarRota(
IN p_origem VARCHAR(100),
IN p_destino VARCHAR(100),
IN p_distancia DECIMAL(10,2),
IN p_data DATE,
IN p_caminhao INT,
IN p_motorista INT,
IN p_cliente INT
)
BEGIN

IF EXISTS(SELECT * FROM Caminhao WHERE id_caminhao=p_caminhao)
AND EXISTS(SELECT * FROM Motorista WHERE id_motorista=p_motorista)
AND EXISTS(SELECT * FROM Cliente_B2B WHERE id_cliente=p_cliente)

THEN

INSERT INTO Rota_Entrega
(origem,destino,distancia_km,data_entrega,id_caminhao,id_motorista,id_cliente)

VALUES
(p_origem,p_destino,p_distancia,p_data,p_caminhao,p_motorista,p_cliente);

ELSE

SELECT 'Dados inválidos.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_CadastrarCarga(
IN p_descricao VARCHAR(100),
IN p_peso DECIMAL(10,2),
IN p_tipo VARCHAR(50),
IN p_rota INT
)
BEGIN

IF EXISTS(SELECT * FROM Rota_Entrega WHERE id_rota=p_rota) THEN

INSERT INTO Carga
(descricao,peso,tipo_carga,id_rota)

VALUES
(p_descricao,p_peso,p_tipo,p_rota);

ELSE

SELECT 'Rota não encontrada.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_RegistrarManutencao(
IN p_data DATE,
IN p_tipo VARCHAR(50),
IN p_custo DECIMAL(10,2),
IN p_descricao TEXT,
IN p_caminhao INT
)
BEGIN

IF EXISTS(SELECT * FROM Caminhao WHERE id_caminhao=p_caminhao) THEN

INSERT INTO Manutencao
(data_manutencao,tipo,custo,descricao,id_caminhao)

VALUES
(p_data,p_tipo,p_custo,p_descricao,p_caminhao);

ELSE

SELECT 'Caminhão não encontrado.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE sp_RegistrarAbastecimento(
IN p_data DATE,
IN p_litros DECIMAL(10,2),
IN p_valor DECIMAL(10,2),
IN p_km INT,
IN p_caminhao INT
)
BEGIN

DECLARE media DECIMAL(10,2);

IF EXISTS(SELECT * FROM Caminhao WHERE id_caminhao=p_caminhao) THEN

SET media = p_km / p_litros;

INSERT INTO Consumo_Combustivel
(data_abastecimento,litros,valor,km_atual,id_caminhao)

VALUES
(p_data,p_litros,p_valor,p_km,p_caminhao);

SELECT media AS km_por_litro;

ELSE

SELECT 'Caminhão não encontrado.' AS Mensagem;

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_caminhao_em_rota
AFTER INSERT ON Rota_Entrega
FOR EACH ROW
BEGIN

UPDATE Caminhao
SET status = 'Em Rota'
WHERE id_caminhao = NEW.id_caminhao;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_verificar_capacidade
BEFORE INSERT ON Carga
FOR EACH ROW
BEGIN

DECLARE capacidade DECIMAL(10,2);

SELECT c.capacidade_carga
INTO capacidade
FROM Caminhao c
JOIN Rota_Entrega r
ON c.id_caminhao = r.id_caminhao
WHERE r.id_rota = NEW.id_rota;

IF NEW.peso > capacidade THEN

SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Peso da carga excede a capacidade do caminhão.';

END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_status_manutencao
AFTER INSERT ON Manutencao
FOR EACH ROW
BEGIN

UPDATE Caminhao
SET status = 'Em Manutenção'
WHERE id_caminhao = NEW.id_caminhao;

END $$

DELIMITER ;

