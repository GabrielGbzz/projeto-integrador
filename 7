CREATE DATABASE FastBite;
USE FastBite;


CREATE TABLE Cliente(
    id_cliente INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    email VARCHAR(100),
    telefone VARCHAR(20),
    endereco VARCHAR(150)
);


CREATE TABLE Restaurante(
    id_restaurante INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    endereco VARCHAR(150),
    telefone VARCHAR(20),
    categoria VARCHAR(50)
);


CREATE TABLE Menu(
    id_menu INT PRIMARY KEY AUTO_INCREMENT,
    nome_prato VARCHAR(100),
    descricao VARCHAR(200),
    preco DECIMAL(10,2),
    
    id_restaurante INT,
    FOREIGN KEY(id_restaurante) 
    REFERENCES Restaurante(id_restaurante)
);


CREATE TABLE Estafeta(
    id_estafeta INT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(100),
    telefone VARCHAR(20),
    veiculo VARCHAR(50),
    status VARCHAR(30)
);


CREATE TABLE Pedido(
    id_pedido INT PRIMARY KEY AUTO_INCREMENT,
    data_pedido DATE,
    status VARCHAR(30),
    valor_total DECIMAL(10,2),

    id_cliente INT,
    id_menu INT,
    id_estafeta INT,

    FOREIGN KEY(id_cliente)
    REFERENCES Cliente(id_cliente),

    FOREIGN KEY(id_menu)
    REFERENCES Menu(id_menu),

    FOREIGN KEY(id_estafeta)
    REFERENCES Estafeta(id_estafeta)
);


CREATE TABLE Avaliacao(
    id_avaliacao INT PRIMARY KEY AUTO_INCREMENT,
    nota INT,
    comentario VARCHAR(200),
    data_avaliacao DATE,

    id_pedido INT,

    FOREIGN KEY(id_pedido)
    REFERENCES Pedido(id_pedido)
);


CREATE TABLE Cupom(
    id_cupom INT PRIMARY KEY AUTO_INCREMENT,
    codigo VARCHAR(50),
    desconto DECIMAL(5,2),
    validade DATE,

    id_pedido INT,

    FOREIGN KEY(id_pedido)
    REFERENCES Pedido(id_pedido)
);

ALTER TABLE Cliente
ADD data_criacao DATE;


ALTER TABLE Restaurante
ADD data_criacao DATE;


ALTER TABLE Menu
ADD data_criacao DATE;


ALTER TABLE Pedido
ADD data_criacao DATE;


ALTER TABLE Estafeta
ADD data_criacao DATE;


ALTER TABLE Avaliacao
ADD data_criacao DATE;


ALTER TABLE Cupom
ADD data_criacao DATE;

DELIMITER //

CREATE PROCEDURE cadastrarCliente(
IN p_nome VARCHAR(100),
IN p_email VARCHAR(100)
)

BEGIN

DECLARE existe INT;

SELECT COUNT(*) INTO existe
FROM Cliente
WHERE email=p_email;


IF existe=0 THEN

INSERT INTO Cliente(nome,email)
VALUES(p_nome,p_email);

ELSE

SELECT 'Cliente já existe';

END IF;

END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE cadastrarRestaurante(
IN p_nome VARCHAR(100),
IN p_categoria VARCHAR(50)
)

BEGIN

DECLARE qtd INT;

SELECT COUNT(*) INTO qtd
FROM Restaurante
WHERE nome=p_nome;


IF qtd=0 THEN

INSERT INTO Restaurante(nome,categoria)
VALUES(p_nome,p_categoria);

ELSE

SELECT 'Restaurante já cadastrado';

END IF;

END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE adicionarPrato(
IN p_nome VARCHAR(100),
IN p_preco DECIMAL(10,2),
IN p_restaurante INT
)

BEGIN

DECLARE existe INT;


SELECT COUNT(*) INTO existe
FROM Restaurante
WHERE id_restaurante=p_restaurante;


IF existe>0 THEN

INSERT INTO Menu(nome_prato,preco,id_restaurante)
VALUES(p_nome,p_preco,p_restaurante);

ELSE

SELECT 'Restaurante inexistente';

END IF;


END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE atualizarEstafeta(
IN p_id INT,
IN p_status VARCHAR(30)
)

BEGIN

DECLARE existe INT;


SELECT COUNT(*) INTO existe
FROM Estafeta
WHERE id_estafeta=p_id;


IF existe>0 THEN

UPDATE Estafeta
SET status=p_status
WHERE id_estafeta=p_id;


ELSE

SELECT 'Estafeta não encontrado';

END IF;


END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE criarPedido(
IN p_cliente INT,
IN p_menu INT,
IN p_valor DECIMAL(10,2)
)

BEGIN

DECLARE clienteExiste INT;


SELECT COUNT(*) INTO clienteExiste
FROM Cliente
WHERE id_cliente=p_cliente;


IF clienteExiste>0 THEN

INSERT INTO Pedido(
data_pedido,
status,
valor_total,
id_cliente,
id_menu
)

VALUES(
CURDATE(),
'Pendente',
p_valor,
p_cliente,
p_menu
);


ELSE

SELECT 'Cliente não existe';

END IF;


END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE registrarAvaliacao(
IN p_nota INT,
IN p_comentario VARCHAR(200),
IN p_pedido INT
)

BEGIN

DECLARE pedidoExiste INT;


SELECT COUNT(*) INTO pedidoExiste
FROM Pedido
WHERE id_pedido=p_pedido;


IF pedidoExiste>0 THEN

INSERT INTO Avaliacao(
nota,
comentario,
data_avaliacao,
id_pedido
)

VALUES(
p_nota,
p_comentario,
CURDATE(),
p_pedido
);


ELSE

SELECT 'Pedido inexistente';

END IF;


END //

DELIMITER ;

DELIMITER //

CREATE PROCEDURE aplicarCupom(
IN p_codigo VARCHAR(50),
IN p_desconto DECIMAL(5,2),
IN p_pedido INT
)

BEGIN

DECLARE valor DECIMAL(10,2);


SELECT valor_total INTO valor
FROM Pedido
WHERE id_pedido=p_pedido;


IF valor IS NOT NULL THEN


UPDATE Pedido
SET valor_total = valor - (valor*p_desconto/100)
WHERE id_pedido=p_pedido;


INSERT INTO Cupom(
codigo,
desconto,
validade,
id_pedido
)

VALUES(
p_codigo,
p_desconto,
DATE_ADD(CURDATE(),INTERVAL 30 DAY),
p_pedido
);


ELSE

SELECT 'Pedido não encontrado';

END IF;


END //

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_status_pedido
BEFORE INSERT ON Pedido
FOR EACH ROW
BEGIN

SET NEW.status = 'Em preparo';

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_estafeta_ocupado
AFTER INSERT ON Pedido
FOR EACH ROW
BEGIN

UPDATE Estafeta
SET status = 'Ocupado'
WHERE id_estafeta = NEW.id_estafeta;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_validar_cupom
BEFORE INSERT ON Cupom
FOR EACH ROW
BEGIN

IF NEW.validade < CURDATE() THEN

SIGNAL SQLSTATE '45000'
SET MESSAGE_TEXT = 'Cupom expirado.';

END IF;

END $$

DELIMITER ;

