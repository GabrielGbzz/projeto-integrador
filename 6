CREATE DATABASE Edugest;
USE Edugest;


CREATE TABLE Aluno (
    id_aluno INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    data_nascimento DATE,
    cpf CHAR(11),
    email VARCHAR(100),
    telefone VARCHAR(20),
    curso VARCHAR(100),
    semestre INT,

    CONSTRAINT uc_aluno_cpf UNIQUE (cpf),
    CONSTRAINT uc_aluno_email UNIQUE (email)
);


CREATE TABLE Disciplina (
    id_disciplina INT AUTO_INCREMENT PRIMARY KEY,
    nome_disciplina VARCHAR(100),
    carga_horaria INT,
    semestre INT
);


CREATE TABLE Professor (
    id_professor INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100),
    email VARCHAR(100),
    telefone VARCHAR(20),
    titulacao VARCHAR(100),

    CONSTRAINT uc_professor_email UNIQUE (email)
);


CREATE TABLE Matricula (
    id_matricula INT AUTO_INCREMENT PRIMARY KEY,
    data_matricula DATE,
    status VARCHAR(20),

    id_aluno INT,
    id_disciplina INT,

        FOREIGN KEY (id_aluno)
        REFERENCES Aluno(id_aluno),

        FOREIGN KEY (id_disciplina)
        REFERENCES Disciplina(id_disciplina)
);


CREATE TABLE Atribuicao (
    id_atribuicao INT AUTO_INCREMENT PRIMARY KEY,
    ano_letivo YEAR,
    semestre INT,

    id_professor INT,
    id_disciplina INT,

        FOREIGN KEY (id_professor)
        REFERENCES Professor(id_professor),

        FOREIGN KEY (id_disciplina)
        REFERENCES Disciplina(id_disciplina)

);


CREATE TABLE Nota (
    id_nota INT AUTO_INCREMENT PRIMARY KEY,
    nota1 DECIMAL(4,2),
    nota2 DECIMAL(4,2),
    media DECIMAL(4,2),
    situacao VARCHAR(20),

    id_matricula INT,

        FOREIGN KEY (id_matricula)
        REFERENCES Matricula(id_matricula)
);


CREATE TABLE Falta (
    id_falta INT AUTO_INCREMENT PRIMARY KEY,
    data_falta DATE,
    quantidade INT,

    id_matricula INT,

        FOREIGN KEY (id_matricula)
        REFERENCES Matricula(id_matricula)
);

ALTER TABLE Aluno
ADD status_ativo BOOLEAN DEFAULT TRUE;

ALTER TABLE Disciplina
ADD data_criacao DATETIME;

ALTER TABLE Professor
ADD status_ativo BOOLEAN;

ALTER TABLE Matricula
ADD usuario_alteracao VARCHAR(50);

ALTER TABLE Atribuicao
ADD observacoes VARCHAR(200);

ALTER TABLE Nota
ADD data_lancamento DATE;

ALTER TABLE Falta
ADD justificativa VARCHAR(200);

DELIMITER $$

CREATE PROCEDURE InserirAluno(

IN p_nome VARCHAR(100),
IN p_data DATE,
IN p_cpf CHAR(11),
IN p_email VARCHAR(100),
IN p_telefone VARCHAR(20),
IN p_curso VARCHAR(100),
IN p_semestre INT

)
BEGIN

IF EXISTS(SELECT * FROM Aluno WHERE cpf=p_cpf) THEN

SELECT 'Aluno já cadastrado.';

ELSE

INSERT INTO Aluno
(nome,data_nascimento,cpf,email,telefone,curso,semestre)

VALUES
(p_nome,p_data,p_cpf,p_email,p_telefone,p_curso,p_semestre);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirDisciplina(

IN p_nome VARCHAR(100),
IN p_carga INT,
IN p_semestre INT

)
BEGIN

IF EXISTS(SELECT * FROM Disciplina WHERE nome_disciplina=p_nome) THEN

SELECT 'Disciplina já cadastrada.';

ELSE

INSERT INTO Disciplina
(nome_disciplina,carga_horaria,semestre)

VALUES
(p_nome,p_carga,p_semestre);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE InserirProfessor(

IN p_nome VARCHAR(100),
IN p_email VARCHAR(100),
IN p_telefone VARCHAR(20),
IN p_titulacao VARCHAR(100)

)
BEGIN

IF EXISTS(SELECT * FROM Professor WHERE email=p_email) THEN

SELECT 'Professor já cadastrado.';

ELSE

INSERT INTO Professor
(nome,email,telefone,titulacao)

VALUES
(p_nome,p_email,p_telefone,p_titulacao);

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RealizarMatricula(

IN p_data DATE,
IN p_status VARCHAR(20),
IN p_aluno INT,
IN p_disciplina INT

)
BEGIN

IF EXISTS(SELECT * FROM Aluno WHERE id_aluno=p_aluno)
AND EXISTS(SELECT * FROM Disciplina WHERE id_disciplina=p_disciplina) THEN

INSERT INTO Matricula
(data_matricula,status,id_aluno,id_disciplina)

VALUES
(p_data,p_status,p_aluno,p_disciplina);

ELSE

SELECT 'Aluno ou disciplina inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE AtribuirProfessor(

IN p_ano YEAR,
IN p_semestre INT,
IN p_professor INT,
IN p_disciplina INT

)
BEGIN

IF EXISTS(SELECT * FROM Professor WHERE id_professor=p_professor)
AND EXISTS(SELECT * FROM Disciplina WHERE id_disciplina=p_disciplina) THEN

INSERT INTO Atribuicao
(ano_letivo,semestre,id_professor,id_disciplina)

VALUES
(p_ano,p_semestre,p_professor,p_disciplina);

ELSE

SELECT 'Professor ou disciplina inexistente.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE LancarNota(

IN p_nota1 DECIMAL(4,2),
IN p_nota2 DECIMAL(4,2),
IN p_matricula INT

)
BEGIN

DECLARE media_final DECIMAL(4,2);
DECLARE situacao_final VARCHAR(20);

SET media_final = (p_nota1 + p_nota2)/2;

IF media_final >= 10 THEN
SET situacao_final='Aprovado';
ELSE
SET situacao_final='Reprovado';
END IF;

INSERT INTO Nota
(nota1,nota2,media,situacao,id_matricula)

VALUES
(p_nota1,p_nota2,media_final,situacao_final,p_matricula);

END$$

DELIMITER ;

DELIMITER $$

CREATE PROCEDURE RegistrarFalta(

IN p_data DATE,
IN p_quantidade INT,
IN p_matricula INT

)
BEGIN

IF EXISTS(SELECT * FROM Matricula WHERE id_matricula=p_matricula) THEN

INSERT INTO Falta
(data_falta,quantidade,id_matricula)

VALUES
(p_data,p_quantidade,p_matricula);

ELSE

SELECT 'Matrícula não encontrada.';

END IF;

END$$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_calcular_media
BEFORE INSERT ON Nota
FOR EACH ROW
BEGIN

SET NEW.media = (NEW.nota1 + NEW.nota2) / 2;

IF NEW.media >= 6 THEN
    SET NEW.situacao = 'Aprovado';
ELSE
    SET NEW.situacao = 'Reprovado';
END IF;

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_status_matricula
BEFORE INSERT ON Matricula
FOR EACH ROW
BEGIN

SET NEW.status = 'Ativa';

END $$

DELIMITER ;

DELIMITER $$

CREATE TRIGGER trg_reprovar_faltas
AFTER INSERT ON Falta
FOR EACH ROW
BEGIN

DECLARE total_faltas INT;

SELECT SUM(quantidade)
INTO total_faltas
FROM Falta
WHERE id_matricula = NEW.id_matricula;

IF total_faltas > 20 THEN

UPDATE Nota
SET situacao = 'Reprovado por Falta'
WHERE id_matricula = NEW.id_matricula;

END IF;

END $$

DELIMITER ;

